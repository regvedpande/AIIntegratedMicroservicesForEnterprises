# ============================================================
# AiEnterprise ECRI - Environment Variables Template
# ============================================================
# 1. Copy this file: cp .env.template .env
# 2. Fill in all <PLACEHOLDER> values
# 3. NEVER commit the .env file to source control
# ============================================================

# SQL Server
SQL_SA_PASSWORD=<STRONG_PASSWORD_MIN_8_CHARS_UPPER_LOWER_DIGIT_SPECIAL>

# Redis
REDIS_PASSWORD=<STRONG_REDIS_PASSWORD>

# JWT Secret (generate with: openssl rand -base64 48)
JWT_SECRET_KEY=<MINIMUM_32_CHARACTER_JWT_SECRET_KEY>

# Gateway API Key (generate with: openssl rand -hex 32)
GATEWAY_API_KEY=<STRONG_GATEWAY_API_KEY>

# Anthropic API Key (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=<YOUR_ANTHROPIC_API_KEY>

# Notifications
ALERT_WEBHOOK_URL=<OPTIONAL_SLACK_OR_TEAMS_WEBHOOK_URL>
ALERT_EMAIL_RECIPIENTS=<COMMA_SEPARATED_EMAIL_LIST>

# Frontend URL (for CORS)
FRONTEND_URL=https://your-app.com
