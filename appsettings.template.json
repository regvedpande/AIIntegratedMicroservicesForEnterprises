{
  "_comment": "TEMPLATE FILE - Copy to appsettings.json per service. NEVER commit appsettings.json with real values.",
  "_envVarPrefix": "Set AIEP_ prefixed environment variables to override any setting.",

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "Server=<SQL_SERVER>;Database=AiEnterpriseDb;Integrated Security=True;Encrypt=True;",
    "Redis": "<REDIS_HOST>:6379,password=<REDIS_PASSWORD>"
  },

  "Jwt": {
    "Issuer": "AiEnterpriseGateway",
    "Audience": "AiEnterprise",
    "Key": "<SAME_KEY_ACROSS_ALL_SERVICES_MIN_32_CHARS>",
    "ExpiryMinutes": 60
  },

  "Anthropic": {
    "ApiKey": "<YOUR_ANTHROPIC_API_KEY>"
  },

  "Gateway": {
    "ApiKey": "<GATEWAY_API_KEY>"
  },

  "Services": {
    "ComplianceServiceUrl": "http://localhost:5001",
    "DocumentIntelligenceUrl": "http://localhost:5002",
    "RiskScoringUrl": "http://localhost:5003",
    "AuditServiceUrl": "http://localhost:5004",
    "NotificationHubUrl": "http://localhost:5005"
  },

  "Notifications": {
    "WebhookUrl": "",
    "AlertEmailRecipients": ""
  }
}
